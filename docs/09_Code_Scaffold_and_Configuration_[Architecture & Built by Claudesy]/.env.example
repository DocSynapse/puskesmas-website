# ============================================================
# .env.example — Puskesmas Balowerti Platform
# Architecture & Built by Claudesy
# Author: dr. Ferdi Iskandar / Claudesy
# Date: 2026-03-03
#
# USAGE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in ALL values marked [REQUIRED]
#   3. NEVER commit .env to git (it is in .gitignore)
#   4. Add secrets to Railway environment variables for production
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Puskesmas Balowerti"
APP_VERSION=1.0.0

# ── Google APIs (Phase 1) ────────────────────────────────────
# [REQUIRED] Obtain from Google Cloud Console
# Restrict to HTTP referrers: https://yourdomain.com/*
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# [REQUIRED] Used by sync-google-reviews.mjs script
GOOGLE_PLACE_QUERY=Puskesmas Balowerti Kediri

# [OPTIONAL] Override the Google Review page URL
# GOOGLE_REVIEW_PAGE_URL=https://www.google.com/search?...

# [OPTIONAL] Override the output path for synced reviews
# GOOGLE_REVIEWS_OUTPUT=public/data/google-reviews.json

# ── Vite Public Variables (available in browser) ─────────────
# Variables prefixed with VITE_ are exposed to the React SPA
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_APP_NAME="Puskesmas Balowerti"
VITE_APP_VERSION=1.0.0

# ── Phase 2: Database (PostgreSQL) ──────────────────────────
# [REQUIRED for Phase 2] Railway auto-provides DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_DB=puskesmas_balowerti
# POSTGRES_USER=puskesmas_user
# POSTGRES_PASSWORD=your_secure_password_here

# ── Phase 2: Authentication ──────────────────────────────────
# [REQUIRED for Phase 2] Generate with: openssl rand -hex 64
# JWT_SECRET=your_jwt_secret_minimum_64_chars
# JWT_REFRESH_SECRET=your_refresh_secret_minimum_64_chars
# JWT_ACCESS_EXPIRY=1h
# JWT_REFRESH_EXPIRY=7d

# ── Phase 2: AI / Anthropic ──────────────────────────────────
# [REQUIRED for Phase 2 AI features]
# Obtain from: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Phase 2: Email Notifications ─────────────────────────────
# [OPTIONAL] For reservation confirmation emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@puskesmasbalowerti.id
# SMTP_PASS=your_app_password_here
# SMTP_FROM="Puskesmas Balowerti <noreply@puskesmasbalowerti.id>"
# ADMIN_EMAIL=admin@puskesmasbalowerti.id

# ── Phase 2: File Storage ─────────────────────────────────────
# [OPTIONAL] For generated report storage
# STORAGE_TYPE=local  # or: s3
# STORAGE_PATH=./storage/reports
# S3_BUCKET=puskesmas-reports
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=your_s3_access_key
# S3_SECRET_KEY=your_s3_secret_key

# ── Analytics ────────────────────────────────────────────────
# [OPTIONAL] Google Analytics 4
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── pgAdmin (development only) ───────────────────────────────
# PGADMIN_EMAIL=admin@puskesmasbalowerti.id
# PGADMIN_PASSWORD=your_pgadmin_password
