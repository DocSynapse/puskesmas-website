# Blueprinted & built by Claudesy.
# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — Puskesmas Balowerti Website
# Copy this file to .env and fill in the required values.
# IMPORTANT: Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Browser-Exposed (VITE_ prefix) ───────────────────────────────────────────
# URL for the Crew Portal (internal staff dashboard) link in the navigation.
# Leave empty to hide the Crew Portal button entirely.
VITE_CREW_PORTAL_URL=

# ── Google Reviews Sync (Node.js only — never exposed to browser) ─────────────
# Google Places API key — required only to run `npm run sync:reviews`.
GOOGLE_MAPS_API_KEY=your_google_places_api_key_here

# Override the public Google review page URL shown in the Testimonials section.
GOOGLE_REVIEW_PAGE_URL=

# Google Places search query used to locate the clinic (default shown below).
GOOGLE_PLACE_QUERY=Puskesmas Balowerti Kediri

# Override the output path for synced reviews JSON (default shown below).
GOOGLE_REVIEWS_OUTPUT=public/data/google-reviews.json
